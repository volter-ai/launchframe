# Local launch credentials.
# Copy to `.env` in this launch workspace. Never commit real values.

# npm publish token. For headless publish on an account with 2FA, this must be
# a granular token with package write permission and 2FA bypass enabled.
NPM_TOKEN=
NODE_AUTH_TOKEN=

# Optional providers used by full launch dress rehearsals.
GITHUB_TOKEN=
NAMECOM_USERNAME=
NAMECOM_TOKEN=
RESEND_API_KEY=
TALLY_API_KEY=
